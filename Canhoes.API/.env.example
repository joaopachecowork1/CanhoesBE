# Copiar para .env e preencher com valores reais
# NUNCA fazer commit do ficheiro .env

# Connection string para SQL Server (produção/staging)
ConnectionStrings__Default=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=Canhoes;User ID=<user>;Password=<password>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Min Pool Size=5;Max Pool Size=100;

# Mock auth (apenas desenvolvimento)
Auth__UseMockAuth=false
Auth__MockUserEmail=dev@canhoes.com

# Google OAuth (produção)
Auth__Google__ClientId=<google-client-id>.apps.googleusercontent.com

# Admin emails allowlist
Auth__AdminEmails__0=teu-email@exemplo.com

# CORS
Cors__OriginsCsv=https://teu-frontend.vercel.app,http://localhost:3000
