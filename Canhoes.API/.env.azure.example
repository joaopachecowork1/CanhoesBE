# Backend settings for Azure Container Apps / Azure App Service
# Copy the values into the cloud provider environment settings.

ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Server=tcp:<sql-server>.database.windows.net,1433;Initial Catalog=Canhoes;Persist Security Info=False;User ID=<sql-admin-user>;Password=<sql-admin-password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
Auth__Google__ClientId=<google-client-id>.apps.googleusercontent.com
Auth__AdminEmails__0=teu-email@exemplo.com
Cors__OriginsCsv=https://teu-frontend.vercel.app,http://localhost:3000
# Optional if you want preview deployments from Vercel:
# Cors__AllowedOriginSuffixesCsv=vercel.app
